# LoreBinders Environment Variables

# API Keys (at least one required depending on chosen model)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Model Configuration (Format: provider:model_name)
LOREBINDERS_EXTRACTION_MODEL=openrouter:bytedance/seed-1.6-flash
LOREBINDERS_ANALYSIS_MODEL=openrouter:deepseek/deepseek-v3.2
LOREBINDERS_SUMMARIZATION_MODEL=openrouter:bytedance/seed-1.6-flash

# Concurrency Control
LOREBINDERS_MAX_CONCURRENCY=10

# Confidence Threshold (0.0 to 1.0)
LOREBINDERS_CONFIDENCE_THRESHOLD=0.8

# Storage Configuration
LOREBINDERS_DB_URL=sqlite:///lorebinders.db
# LOREBINDERS_WORKSPACE_BASE_PATH=./work
